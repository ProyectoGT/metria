NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# URL pública de la app (necesaria para los enlaces en emails y OAuth redirects)
NEXT_PUBLIC_BASE_URL=https://tu-dominio.vercel.app

# Google Calendar OAuth 2.0 — configura en https://console.cloud.google.com
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret

# Email (opcional) — obtén tu API key en https://resend.com
# Si no se configura, los tickets se guardan pero no se envía email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=soporte@tu-dominio.com

# Contraseña de confirmación para operaciones destructivas (eliminar zonas, fincas, etc.)
# Alternativa: configúrala desde el panel Cuenta > Seguridad (se guarda en BD)
DELETE_CONFIRMATION_PASSWORD=
