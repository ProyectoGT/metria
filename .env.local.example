NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# URL pública de la app (necesaria para los enlaces en emails y OAuth redirects)
NEXT_PUBLIC_BASE_URL=https://tu-dominio.vercel.app

# Google Calendar OAuth 2.0 — configura en https://console.cloud.google.com
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret

# Cifrado server-side de access_token/refresh_token de Gmail.
# Usa un valor largo y estable. Si cambia, los tokens guardados no se podran descifrar.
EMAIL_TOKEN_ENCRYPTION_KEY=pon-aqui-un-secreto-largo-de-32-o-mas-caracteres

# Email (opcional) — obtén tu API key en https://resend.com
# Si no se configura, los tickets se guardan pero no se envía email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=soporte@tu-dominio.com

# Contraseña de confirmación para operaciones destructivas (eliminar zonas, fincas, etc.)
# Alternativa: configúrala desde el panel Cuenta > Seguridad (se guarda en BD)
DELETE_CONFIRMATION_PASSWORD=

# ─── WhatsApp — Proveedor y configuración ────────────────────────────────────
#
# WHATSAPP_PROVIDER: proveedor activo
#   manual   → solo wa.me (modo actual por defecto)
#   meta     → WhatsApp Cloud API oficial de Meta
#   openwa   → OpenWA self-hosted (requiere OPENWA_* abajo)
#
WHATSAPP_PROVIDER=manual
WHATSAPP_FALLBACK_PROVIDER=manual

# WhatsApp Cloud API (Meta) — necesario solo si WHATSAPP_PROVIDER=meta
# Obtén las credenciales en https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# OpenWA self-hosted — necesario solo si WHATSAPP_PROVIDER=openwa
# Levanta el servicio con: git clone https://github.com/rmyndharis/OpenWA && docker compose up -d
# API:       http://localhost:2785/api
# Dashboard: http://localhost:2886
OPENWA_BASE_URL=http://localhost:2785/api
OPENWA_API_KEY=
OPENWA_DEFAULT_SESSION_NAME=metria-main
OPENWA_DEFAULT_SESSION_ID=
OPENWA_WEBHOOK_SECRET=
OPENWA_TIMEOUT_MS=10000

# Observabilidad — Sentry (opcional)
# Si se configura, los errores se enviarán a Sentry además del logger interno
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxxx.ingest.us.sentry.io/xxxxxx
# SENTRY_ENVIRONMENT=production
